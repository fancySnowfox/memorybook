<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Memorybook Creator - Memory organizer</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    #chatPanel { display: flex; }
    #toolsDrawer { transform: translateX(100%); transition: transform 0.3s ease; }
    #toolsDrawer.open { transform: translateX(0); }
    #drawerOverlay { display: none; }
    #drawerOverlay.open { display: block; }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 h-16 bg-gradient-to-r from-blue-600 to-blue-700 shadow-md text-white z-50 flex items-center justify-between px-6">
    <a href="/" class="flex items-center gap-3 no-underline">
      <img src="/SnowfoxConsulting.png" alt="Memorybook Creator" width="48" height="48" class="w-12 h-12 object-contain">
      <span class="text-xl font-semibold">Memorybook Creator</span>
    </a>
    <nav class="flex items-center gap-4">
      <button id="openToolsBtn" class="flex items-center gap-2 bg-white/20 hover:bg-white/30 text-white font-medium px-4 py-2 rounded-md transition-colors text-sm">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        Files &amp; Tools
      </button>
    </nav>
  </header>

  <!-- Drawer Overlay -->
  <div id="drawerOverlay" class="fixed inset-0 bg-black/40 z-40"></div>

  <!-- Tools & Files Drawer -->
  <div id="toolsDrawer" class="fixed top-0 right-0 h-full w-full max-w-md bg-white shadow-2xl z-50 flex flex-col overflow-y-auto">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 sticky top-0 bg-white">
      <h2 class="text-lg font-semibold text-gray-900">Files &amp; Tools</h2>
      <button id="closeToolsBtn" class="text-gray-500 hover:text-gray-700 focus:outline-none">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="p-6 space-y-8">

      <!-- Tab Headers -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <div class="flex border-b border-gray-200 mb-6">
          <button id="tabVideoBtn" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600 focus:outline-none" data-tab="tabVideo">
            Video Converter
          </button>
          <button id="tabPdfBtn" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 focus:outline-none" data-tab="tabPdf">
            PDF Upload
          </button>
        </div>

        <!-- Tab: Video Converter -->
        <div id="tabVideo" class="tab-panel">
          <div class="flex flex-col items-center text-center mb-4">
            <div class="bg-blue-100 rounded-full p-4 mb-4">
              <svg class="h-10 w-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14m-6 4h4a2 2 0 002-2V8a2 2 0 00-2-2H9a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </div>
            <p class="text-gray-600">Convert iPad MOV to H.264 MP4 and target under 10MB.</p>
          </div>
          <form id="videoConvertForm" class="space-y-4">
            <div>
              <label for="movFile" class="block text-sm font-medium text-gray-700 mb-2">Select .MOV file</label>
              <input id="movFile" name="video" type="file" accept=".mov,video/quicktime" class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:border-0 file:rounded-md file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" required>
            </div>
            <div>
              <label for="maxWidth" class="block text-sm font-medium text-gray-700 mb-2">Max resolution width</label>
              <select id="maxWidth" name="maxWidth" class="block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none">
                <option value="">Auto (best effort for 10MB)</option>
                <option value="1920">1080p (1920px)</option>
                <option value="1280">720p (1280px)</option>
                <option value="960">960px</option>
                <option value="720">720px</option>
                <option value="640">640px</option>
                <option value="480">480px</option>
              </select>
            </div>
            <button id="convertBtn" type="submit" class="w-full bg-blue-600 hover:bg-blue-700 disabled:bg-blue-300 text-white font-medium py-2.5 px-4 rounded-md transition-colors">
              Convert and Download
            </button>
            <p id="convertStatus" class="text-sm text-gray-600 min-h-[1.25rem]"></p>
          </form>
        </div>

        <!-- Tab: PDF Upload -->
        <div id="tabPdf" class="tab-panel hidden">
          <div class="flex flex-col items-center text-center mb-4">
            <div class="bg-red-100 rounded-full p-4 mb-4">
              <svg class="h-10 w-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <p class="text-gray-600">Upload PDF files to the server file library.</p>
          </div>
          <form id="pdfUploadForm" class="space-y-4">
            <div>
              <label for="pdfFile" class="block text-sm font-medium text-gray-700 mb-2">Select PDF, DOCX, PPTX, or XLSX file</label>
              <input id="pdfFile" name="file" type="file" accept=".pdf,.docx,.pptx,.xlsx,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:border-0 file:rounded-md file:bg-red-50 file:text-red-700 hover:file:bg-red-100" required>
            </div>
            <button id="pdfUploadBtn" type="submit" class="w-full bg-red-600 hover:bg-red-700 disabled:bg-red-300 text-white font-medium py-2.5 px-4 rounded-md transition-colors">
              Upload File
            </button>
            <p id="pdfUploadStatus" class="text-sm text-gray-600 min-h-[1.25rem]"></p>
          </form>
        </div>
      </div>

      <!-- File Browser -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
            </svg>
            My Files
            <span id="sessionLabel" class="text-xs font-normal text-gray-400 bg-gray-100 px-2 py-0.5 rounded font-mono"></span>
          </h2>
          <div class="flex items-center gap-3">
            <button id="resetFolderBtn" class="text-xs text-amber-600 hover:text-amber-700">Reset</button>
            <button id="refreshFilesBtn" class="text-xs text-blue-600 hover:text-blue-800 flex items-center gap-1">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              Refresh
            </button>
          </div>
        </div>
        <div id="fileList">
          <p class="text-gray-400 text-sm text-center py-8">Loading files…</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Main Content -->
  <div class="pt-16 min-h-screen bg-gray-50 flex flex-col">
    <!-- Title Banner -->
    <div class="text-center py-8 bg-gray-50 border-b border-gray-200">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">Memorybook Creator AI</h1>
      <p class="text-lg text-gray-600">Create and organize your memories with intelligent AI</p>
    </div>
    <!-- Split Layout -->
    <div class="flex flex-1 overflow-hidden">
    <!-- Left: Chat Panel (always visible, full width) -->
    <div id="chatPanel" class="w-full bg-white shadow-lg flex flex-col">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Memory organizer</h2>
        <div class="inline-flex rounded-md border border-gray-300 overflow-hidden" role="group" aria-label="Chat scope selector">
          <button id="scopeAppBtn" type="button" class="chat-scope-btn px-3 py-1.5 text-xs font-medium bg-blue-600 text-white" data-scope="app">App</button>
          <button id="scopeGeneralBtn" type="button" class="chat-scope-btn px-3 py-1.5 text-xs font-medium bg-white text-gray-700" data-scope="general">General</button>
        </div>
      </div>
      <div id="chatMessages" class="flex-1 overflow-y-auto p-6 space-y-4" style="max-height: calc(100vh - 280px);"></div>
      <form id="chatInputForm" class="border-t border-gray-200 p-4">
        <div class="flex gap-2">
          <input id="chatInput" type="text" placeholder="Ask me anything..." class="flex-1 rounded-md border border-gray-300 px-4 py-2 text-sm focus:border-blue-500 focus:outline-none" />
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md transition-colors">
            Send
          </button>
        </div>
        <p id="chatScopeLabel" class="text-xs text-blue-600 mt-2">Mode: App context (local Memorybook data first)</p>
        <p id="chatStatus" class="text-xs text-gray-500 mt-2"></p>
      </form>
    </div>

    <!-- Right: Tools and Files panel removed (now a drawer) -->
    </div>
  </div>

  <script>
    // Drawer toggle
    const toolsDrawer = document.getElementById('toolsDrawer');
    const drawerOverlay = document.getElementById('drawerOverlay');

    document.getElementById('openToolsBtn').addEventListener('click', () => {
      toolsDrawer.classList.add('open');
      drawerOverlay.classList.add('open');
      loadFiles();
    });

    function closeDrawer() {
      toolsDrawer.classList.remove('open');
      drawerOverlay.classList.remove('open');
    }

    document.getElementById('closeToolsBtn').addEventListener('click', closeDrawer);
    drawerOverlay.addEventListener('click', closeDrawer);

    // Chat messaging
    let conversationHistory = [];
    let chatScope = 'app';

    function setChatScope(nextScope) {
      chatScope = nextScope === 'general' ? 'general' : 'app';
      const appBtn = document.getElementById('scopeAppBtn');
      const generalBtn = document.getElementById('scopeGeneralBtn');
      const label = document.getElementById('chatScopeLabel');

      const appActive = chatScope === 'app';
      appBtn.classList.toggle('bg-blue-600', appActive);
      appBtn.classList.toggle('text-white', appActive);
      appBtn.classList.toggle('bg-white', !appActive);
      appBtn.classList.toggle('text-gray-700', !appActive);

      generalBtn.classList.toggle('bg-blue-600', !appActive);
      generalBtn.classList.toggle('text-white', !appActive);
      generalBtn.classList.toggle('bg-white', appActive);
      generalBtn.classList.toggle('text-gray-700', appActive);

      label.textContent = appActive
        ? 'Mode: App context (local Memorybook data first)'
        : 'Mode: General AI (broader knowledge, no local file routing)';
    }

    document.querySelectorAll('.chat-scope-btn').forEach((btn) => {
      btn.addEventListener('click', () => setChatScope(btn.dataset.scope));
    });

    async function sendChatMessage() {
      const input = document.getElementById('chatInput');
      const message = input.value.trim();
      if (!message) return;

      input.value = '';
      addChatMessage(message, 'user');

      const statusEl = document.getElementById('chatStatus');
      statusEl.textContent = 'Thinking...';

      try {
        conversationHistory.push({ role: 'user', content: message });

        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Browser-Id': getBrowserOwnerId(),
          },
          body: JSON.stringify({ messages: conversationHistory, scope: chatScope }),
        });

        if (!response.ok) {
          throw new Error(`API error: ${response.status}`);
        }

        const contentType = (response.headers.get('content-type') || '').toLowerCase();
        let assistantMessage = '';

        // Current backend returns plain text. Keep SSE parsing as a fallback for compatibility.
        if (contentType.includes('text/plain')) {
          assistantMessage = await response.text();
          addChatMessage(assistantMessage || '(empty response)', 'assistant');
        } else {
          const reader = response.body.getReader();
          const decoder = new TextDecoder();
          let messageEl = null;
          let buffered = '';

          while (true) {
            const { done, value } = await reader.read();
            if (done) break;

            buffered += decoder.decode(value, { stream: true });
            const lines = buffered.split('\n');
            buffered = lines.pop() || '';

            for (const line of lines) {
              if (!line.startsWith('data: ')) continue;
              try {
                const data = JSON.parse(line.slice(6));
                if (data.delta?.content) {
                  assistantMessage += data.delta.content;
                  if (!messageEl) {
                    messageEl = addChatMessage('', 'assistant');
                  }
                  messageEl.textContent = assistantMessage;
                  document.getElementById('chatMessages').scrollTop = document.getElementById('chatMessages').scrollHeight;
                }
              } catch (e) { /* ignore malformed stream chunks */ }
            }
          }

          if (!assistantMessage && buffered.trim().length > 0) {
            assistantMessage = buffered.trim();
            addChatMessage(assistantMessage, 'assistant');
          }
        }

        conversationHistory.push({ role: 'assistant', content: assistantMessage || '(empty response)' });
        statusEl.textContent = '';
      } catch (error) {
        addChatMessage(`Error: ${error.message}`, 'error');
        statusEl.textContent = '';
      }
    }

    function addChatMessage(content, role) {
      const messagesEl = document.getElementById('chatMessages');
      const msgEl = document.createElement('div');
      const bgClass = role === 'user' ? 'bg-blue-100 text-blue-900 ml-auto' : role === 'error' ? 'bg-red-100 text-red-900' : 'bg-green-100 text-green-900';
      msgEl.className = `p-4 rounded-lg max-w-xs lg:max-w-sm break-words ${bgClass}`;
      msgEl.textContent = content;
      messagesEl.appendChild(msgEl);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return msgEl;
    }

    document.getElementById('chatInputForm').addEventListener('submit', (e) => {
      e.preventDefault();
      sendChatMessage();
    });

    setChatScope('app');

    const BROWSER_OWNER_KEY = 'snowfoxBrowserOwnerId';

  </script>
  <script>
    // Browser owner ID and file management

    function newBrowserOwnerId() {
      return `b_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 10)}`;
    }

    function getBrowserOwnerId() {
      let id = localStorage.getItem(BROWSER_OWNER_KEY);
      if (!id) {
        id = newBrowserOwnerId();
        localStorage.setItem(BROWSER_OWNER_KEY, id);
      }
      return id;
    }

    function setFolderLabel() {
      const el = document.getElementById('sessionLabel');
      const id = getBrowserOwnerId();
      if (el) {
        el.textContent = `folder: ${id.slice(0, 12)}…`;
        el.title = id;
      }
    }

    function fileApiHeaders() {
      return {
        'X-Browser-Id': getBrowserOwnerId(),
      };
    }

    async function readApiResponse(response) {
      const raw = await response.text();
      const contentType = response.headers.get('content-type') || '';
      let json = null;

      if (contentType.includes('application/json')) {
        try {
          json = JSON.parse(raw);
        } catch (_) {
          json = null;
        }
      }

      return { raw, json, contentType };
    }

    // ── Tab switching ──────────────────────────────────────────────────────────
    (function () {
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabPanels = document.querySelectorAll('.tab-panel');

      tabBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = btn.dataset.tab;
          tabBtns.forEach((b) => {
            b.classList.toggle('border-blue-600', b.dataset.tab === target);
            b.classList.toggle('text-blue-600', b.dataset.tab === target);
            b.classList.toggle('border-transparent', b.dataset.tab !== target);
            b.classList.toggle('text-gray-500', b.dataset.tab !== target);
          });
          tabPanels.forEach((p) => p.classList.toggle('hidden', p.id !== target));
        });
      });
    })();

    // ── Video converter ────────────────────────────────────────────────────────
    (function () {
      const form = document.getElementById('videoConvertForm');
      const fileInput = document.getElementById('movFile');
      const maxWidthSelect = document.getElementById('maxWidth');
      const button = document.getElementById('convertBtn');
      const statusEl = document.getElementById('convertStatus');

      if (!form || !fileInput || !maxWidthSelect || !button || !statusEl) {
        return;
      }

      function setStatus(text, isError) {
        statusEl.textContent = text;
        statusEl.className = `text-sm min-h-[1.25rem] ${isError ? 'text-red-600' : 'text-gray-600'}`;
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const file = fileInput.files && fileInput.files[0];
        if (!file) {
          setStatus('Please select a .MOV file first.', true);
          return;
        }

        button.disabled = true;
        setStatus('Converting video… this can take a minute for larger files.', false);

        try {
          const formData = new FormData();
          formData.append('video', file);
          if (maxWidthSelect.value) {
            formData.append('maxWidth', maxWidthSelect.value);
          }

          const response = await fetch('/api/video/convert', {
            method: 'POST',
            body: formData,
          });

          if (!response.ok) {
            const { raw, json } = await readApiResponse(response);
            let message = `Conversion failed (${response.status})`;
            if (json?.message) {
              message = json.message;
            } else if (json?.error?.message) {
              message = json.error.message;
            } else if (raw && raw.trim().startsWith('<')) {
              message = `Conversion failed (${response.status}). Upstream returned HTML (likely Nginx/proxy).`;
            } else if (raw.trim()) {
              message = raw.trim().slice(0, 240);
            }
            throw new Error(message);
          }

          const blob = await response.blob();
          const suggestedName = file.name.replace(/\.[^.]+$/, '') + '.mp4';
          const downloadUrl = URL.createObjectURL(blob);
          const link = document.createElement('a');
          link.href = downloadUrl;
          link.download = suggestedName;
          document.body.appendChild(link);
          link.click();
          link.remove();
          URL.revokeObjectURL(downloadUrl);

          const sizeHeader = response.headers.get('X-Output-Size-MB');
          const sizeText = sizeHeader ? ` Output size: ${sizeHeader} MB.` : '';
          setStatus(`Done.${sizeText}`, false);
        } catch (error) {
          setStatus(error instanceof Error ? error.message : 'Conversion failed.', true);
        } finally {
          button.disabled = false;
        }
      });
    })();

    // ── PDF upload ─────────────────────────────────────────────────────────────
    (function () {
      const form = document.getElementById('pdfUploadForm');
      const fileInput = document.getElementById('pdfFile');
      const button = document.getElementById('pdfUploadBtn');
      const statusEl = document.getElementById('pdfUploadStatus');

      if (!form || !fileInput || !button || !statusEl) return;

      function setStatus(text, isError) {
        statusEl.textContent = text;
        statusEl.className = `text-sm min-h-[1.25rem] ${isError ? 'text-red-600' : 'text-gray-600'}`;
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const file = fileInput.files && fileInput.files[0];
        if (!file) { setStatus('Please select a file first.', true); return; }

        button.disabled = true;
        setStatus('Uploading…', false);

        try {
          const formData = new FormData();
          formData.append('file', file);

          const response = await fetch('/api/files/upload', {
            method: 'POST',
            headers: fileApiHeaders(),
            body: formData,
          });

          const { raw, json } = await readApiResponse(response);
          if (!response.ok) {
            let message = 'Upload failed.';
            if (json?.message) {
              message = json.message;
            } else if (raw && raw.trim().startsWith('<')) {
              message = `Upload failed (${response.status}). Upstream returned HTML (likely Nginx/proxy).`;
            } else if (raw.trim()) {
              message = raw.trim().slice(0, 240);
            }
            throw new Error(message);
          }

          if (!json || !json.file) {
            throw new Error('Upload succeeded but response was not valid JSON.');
          }

          const message = json.file.converted
            ? `Uploaded and converted to PDF: ${json.file.originalName}`
            : `Uploaded: ${json.file.originalName}`;
          setStatus(message, false);
          form.reset();
          loadFiles();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : 'Upload failed.', true);
        } finally {
          button.disabled = false;
        }
      });
    })();

    // ── File browser ───────────────────────────────────────────────────────────
    async function loadFiles() {
      const listEl = document.getElementById('fileList');
      if (!listEl) return;

      listEl.innerHTML = '<p class="text-gray-400 text-sm text-center py-8">Loading…</p>';

      try {
        const response = await fetch('/api/files', {
          headers: fileApiHeaders(),
        });
        const { raw, json } = await readApiResponse(response);
        if (!response.ok) {
          let message = 'Failed to load files.';
          if (json?.message) {
            message = json.message;
          } else if (raw && raw.trim().startsWith('<')) {
            message = `Failed to load files (${response.status}). Upstream returned HTML (likely Nginx/proxy).`;
          } else if (raw.trim()) {
            message = raw.trim().slice(0, 240);
          }
          throw new Error(message);
        }

        if (!json) {
          throw new Error('File list response was not valid JSON.');
        }

        const files = json.files;
        if (!files || files.length === 0) {
          listEl.innerHTML = '<p class="text-gray-400 text-sm text-center py-8">No files uploaded yet.</p>';
          return;
        }

        listEl.innerHTML = '';
        const table = document.createElement('table');
        table.className = 'w-full text-sm text-left';
        table.innerHTML = `
          <thead>
            <tr class="border-b border-gray-200 text-gray-500 text-xs uppercase">
              <th class="py-2 pr-4 font-medium">File Name</th>
              <th class="py-2 pr-4 font-medium">Size</th>
              <th class="py-2 pr-4 font-medium">Uploaded</th>
              <th class="py-2 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody id="fileTableBody"></tbody>
        `;
        listEl.appendChild(table);
        const tbody = document.getElementById('fileTableBody');

        files.forEach((file) => {
          const sizeMb = (file.size / (1024 * 1024)).toFixed(2);
          const date = new Date(file.uploadedAt).toLocaleString();
          const tr = document.createElement('tr');
          tr.className = 'border-b border-gray-100 hover:bg-gray-50';
          tr.innerHTML = `
            <td class="py-3 pr-4 text-gray-800 font-medium flex items-center gap-2">
              <svg class="h-4 w-4 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
              ${escapeHtml(file.originalName)}
            </td>
            <td class="py-3 pr-4 text-gray-500">${sizeMb} MB</td>
            <td class="py-3 pr-4 text-gray-500">${escapeHtml(date)}</td>
            <td class="py-3 text-right space-x-3">
              <a href="/api/files/${encodeURIComponent(file.name)}?bid=${encodeURIComponent(getBrowserOwnerId())}" class="text-blue-600 hover:text-blue-800" download>Download</a>
              <button class="text-red-500 hover:text-red-700 delete-btn" data-name="${escapeHtml(file.name)}">Delete</button>
            </td>
          `;
          tbody.appendChild(tr);
        });

        tbody.querySelectorAll('.delete-btn').forEach((btn) => {
          btn.addEventListener('click', async () => {
            if (!confirm(`Delete "${btn.dataset.name}"?`)) return;
            try {
              const res = await fetch(`/api/files/${encodeURIComponent(btn.dataset.name)}/delete`, {
                method: 'POST',
                headers: fileApiHeaders(),
              });
              const { raw, json } = await readApiResponse(res);
              if (!res.ok) {
                let message = 'Delete failed.';
                if (json?.message) {
                  message = json.message;
                } else if (raw && raw.trim().startsWith('<')) {
                  message = `Delete failed (${res.status}). Upstream returned HTML (likely Nginx/proxy).`;
                } else if (raw.trim()) {
                  message = raw.trim().slice(0, 240);
                }
                throw new Error(message);
              }
              loadFiles();
            } catch (error) {
              alert(error instanceof Error ? error.message : 'Delete failed.');
            }
          });
        });
      } catch (error) {
        listEl.innerHTML = `<p class="text-red-500 text-sm text-center py-8">${escapeHtml(error.message)}</p>`;
      }
    }

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    document.getElementById('refreshFilesBtn').addEventListener('click', loadFiles);
    document.getElementById('resetFolderBtn').addEventListener('click', () => {
      if (!confirm('Create a new folder identity? You will no longer see files from the current folder in this browser.')) {
        return;
      }

      localStorage.setItem(BROWSER_OWNER_KEY, newBrowserOwnerId());
      setFolderLabel();
      loadFiles();
    });
    loadFiles();

    // Show stable browser-owner folder ID in the header.
    setFolderLabel();
  </script>
</body>
</html>
